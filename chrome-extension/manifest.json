{
  "manifest_version": 3,
  "name": "ReBang Omnibox Redirect",
  "version": "1.0.0",
  "description": "Use !bang shortcuts in the address bar and keep your default search engine for normal autocomplete.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "omnibox": {
    "keyword": "!"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ReBang Omnibox Redirect",
    "default_popup": "popup.html"
  },
  "permissions": [
    "search"
  ]
}
